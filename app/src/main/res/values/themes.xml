<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Studio_creativo_pixel" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/primary_cyan</item>
        <item name="colorOnPrimary">@color/base_background</item>
        
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/secondary_purple</item>
        <item name="colorOnSecondary">@color/text_primary</item>

        <!-- Status bar color. -->
        <item name="android:statusBarColor" tools:targetApi="l">@color/base_background</item>
        <item name="android:windowBackground">@color/base_background</item>

        <!-- Text Colors -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_muted</item>

        <!-- Default Fonts -->
        <item name="fontFamily">@font/outfit_regular</item>
    </style>

    <style name="Theme.Studio_creativo_pixel" parent="Base.Theme.Studio_creativo_pixel" />

    <!-- Typography Styles -->
    <style name="TextAppearance.StudioCreativo.Headline" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="fontFamily">@font/spacegrotesk_bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.StudioCreativo.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="fontFamily">@font/spacegrotesk_medium</item>
        <item name="android:textColor">@color/primary_cyan</item>
    </style>

    <style name="TextAppearance.StudioCreativo.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="fontFamily">@font/outfit_regular</item>
        <item name="android:textColor">@color/text_muted</item>
    </style>

    <style name="TextAppearance.StudioCreativo.Mono" parent="TextAppearance.Material3.BodySmall">
        <item name="fontFamily">@font/jetbrainsmono_bold</item> <!-- Changed to Bold for contrast -->
        <item name="android:textColor">@color/secondary_purple</item>
    </style>

    <style name="TextAppearance.StudioCreativo.NavMenu" parent="TextAppearance.Material3.LabelLarge">
        <item name="fontFamily">@font/spacegrotesk_semibold</item>
        <item name="android:textSize">16sp</item>
        <item name="android:letterSpacing">0.05</item>
    </style>

    <!-- Custom Buttons -->
    <style name="Widget.StudioCreativo.Button.Primary" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/primary_cyan</item>
        <item name="android:textColor">@color/base_background</item>
        <item name="android:textAllCaps">true</item>
        <item name="fontFamily">@font/spacegrotesk_bold</item>
        <item name="cornerRadius">10dp</item>
        <item name="elevation">8dp</item>
    </style>

    <style name="Widget.StudioCreativo.Button.Secondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textColor">@color/primary_cyan</item>
        <item name="strokeColor">@color/primary_cyan</item>
        <item name="strokeWidth">2dp</item>
        <item name="android:textAllCaps">true</item>
        <item name="fontFamily">@font/spacegrotesk_bold</item>
        <item name="cornerRadius">10dp</item>
    </style>

    <style name="Widget.StudioCreativo.Button.Cyan" parent="Widget.StudioCreativo.Button.Primary">
        <item name="backgroundTint">@color/primary_cyan</item>
        <item name="android:textColor">@color/base_background</item>
    </style>

    <style name="Widget.StudioCreativo.Button.Purple" parent="Widget.StudioCreativo.Button.Primary">
        <item name="backgroundTint">@color/secondary_purple</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="Widget.StudioCreativo.Button.Green" parent="Widget.StudioCreativo.Button.Primary">
        <item name="backgroundTint">@color/success_neon_green</item>
        <item name="android:textColor">@color/base_background</item>
    </style>

    <!-- Custom Cards -->
    <style name="Widget.StudioCreativo.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/surface_color</item>
        <item name="cardCornerRadius">14dp</item>
        <item name="strokeColor">@color/border_default</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- Custom Text Fields -->
    <style name="Widget.StudioCreativo.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/elevated_color</item>
        <item name="boxStrokeColor">@color/primary_cyan</item>
        <item name="hintTextColor">@color/primary_cyan</item>
        <item name="android:textColorHint">@color/text_muted</item>
        <item name="boxCornerRadiusTopStart">8dp</item>
        <item name="boxCornerRadiusTopEnd">8dp</item>
        <item name="boxCornerRadiusBottomStart">8dp</item>
        <item name="boxCornerRadiusBottomEnd">8dp</item>
    </style>

    <style name="Widget.StudioCreativo.Chip.Cyan" parent="Widget.Material3.Chip.Filter">
        <item name="chipBackgroundColor">@color/primary_cyan</item>
        <item name="android:textColor">@color/base_background</item>
        <item name="chipStrokeColor">@color/primary_cyan</item>
    </style>

    <style name="Widget.StudioCreativo.Chip.Purple" parent="Widget.Material3.Chip.Filter">
        <item name="chipBackgroundColor">@color/secondary_purple</item>
        <item name="android:textColor">@color/base_background</item>
        <item name="chipStrokeColor">@color/secondary_purple</item>
    </style>

    <style name="Widget.StudioCreativo.Chip.Green" parent="Widget.Material3.Chip.Filter">
        <item name="chipBackgroundColor">@color/success_neon_green</item>
        <item name="android:textColor">@color/base_background</item>
        <item name="chipStrokeColor">@color/success_neon_green</item>
    </style>
</resources>