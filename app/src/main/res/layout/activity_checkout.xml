<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/base_background"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <TextView
            android:id="@+id/checkout_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/checkout_title"
            style="@style/TextAppearance.StudioCreativo.Headline"
            android:textSize="24sp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/step1_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/checkout_step1"
            android:layout_marginTop="24dp"
            style="@style/TextAppearance.StudioCreativo.Mono"
            android:textColor="@color/primary_cyan"
            app:layout_constraintTop_toBottomOf="@id/checkout_title"
            app:layout_constraintStart_toStartOf="parent" />

        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/payment_group"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:singleSelection="true"
            app:selectionRequired="true"
            app:layout_constraintTop_toBottomOf="@id/step1_label">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_pse"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/payment_pse"
                app:strokeColor="@color/primary_cyan"
                android:textColor="@color/text_primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_card"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/payment_card"
                app:strokeColor="@color/primary_cyan"
                android:textColor="@color/text_primary" />

        </com.google.android.material.button.MaterialButtonToggleGroup>

        <TextView
            android:id="@+id/step2_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/checkout_step2"
            android:layout_marginTop="32dp"
            style="@style/TextAppearance.StudioCreativo.Mono"
            android:textColor="@color/primary_cyan"
            app:layout_constraintTop_toBottomOf="@id/payment_group"
            app:layout_constraintStart_toStartOf="parent" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/holder_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/holder_name_hint"
            android:layout_marginTop="8dp"
            style="@style/Widget.StudioCreativo.TextInputLayout"
            app:layout_constraintTop_toBottomOf="@id/step2_label">
            <com.google.android.material.textfield.TextInputEditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/doc_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/doc_number_hint"
            android:layout_marginTop="12dp"
            style="@style/Widget.StudioCreativo.TextInputLayout"
            app:layout_constraintTop_toBottomOf="@id/holder_layout">
            <com.google.android.material.textfield.TextInputEditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:textColor="@color/text_primary" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/card_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/card_number_hint"
            android:layout_marginTop="12dp"
            style="@style/Widget.StudioCreativo.TextInputLayout"
            app:layout_constraintTop_toBottomOf="@id/doc_layout">
            <com.google.android.material.textfield.TextInputEditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="phone"
                android:textColor="@color/text_primary" />
        </com.google.android.material.textfield.TextInputLayout>

        <LinearLayout
            android:id="@+id/expiry_cvv_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp"
            android:baselineAligned="false"
            app:layout_constraintTop_toBottomOf="@id/card_layout">

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:hint="@string/expiry_hint"
                style="@style/Widget.StudioCreativo.TextInputLayout">
                <com.google.android.material.textfield.TextInputEditText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:hint="@string/cvv_hint"
                style="@style/Widget.StudioCreativo.TextInputLayout">
                <com.google.android.material.textfield.TextInputEditText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberPassword"
                    android:textColor="@color/text_primary" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/summary_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            style="@style/Widget.StudioCreativo.Card"
            app:layout_constraintTop_toBottomOf="@id/expiry_cvv_container">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:id="@+id/label_subtotal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:layout_toStartOf="@+id/val_subtotal"
                        android:text="@string/summary_subtotal"
                        style="@style/TextAppearance.StudioCreativo.Body" />
                    <TextView
                        android:id="@+id/val_subtotal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="@string/checkout_subtotal_val"
                        style="@style/TextAppearance.StudioCreativo.Mono" />
                </RelativeLayout>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp">
                    <TextView
                        android:id="@+id/label_iva"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:layout_toStartOf="@+id/val_iva"
                        android:text="@string/summary_iva"
                        style="@style/TextAppearance.StudioCreativo.Body" />
                    <TextView
                        android:id="@+id/val_iva"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="@string/checkout_iva_val"
                        style="@style/TextAppearance.StudioCreativo.Mono" />
                </RelativeLayout>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp">
                    <TextView
                        android:id="@+id/label_discount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:layout_toStartOf="@+id/val_discount"
                        android:text="@string/summary_discount"
                        style="@style/TextAppearance.StudioCreativo.Body"
                        android:textColor="@color/success_neon_green" />
                    <TextView
                        android:id="@+id/val_discount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="@string/checkout_discount_val"
                        style="@style/TextAppearance.StudioCreativo.Mono"
                        android:textColor="@color/success_neon_green" />
                </RelativeLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/border_default"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="16dp" />

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:id="@+id/label_total"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:layout_toStartOf="@+id/val_total"
                        android:text="@string/summary_total"
                        style="@style/TextAppearance.StudioCreativo.Title" />
                    <TextView
                        android:id="@+id/val_total"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="@string/checkout_total_val"
                        style="@style/TextAppearance.StudioCreativo.Title"
                        android:textColor="@color/primary_cyan" />
                </RelativeLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_pay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_pay_now"
            android:layout_marginTop="24dp"
            style="@style/Widget.StudioCreativo.Button.Cyan"
            app:layout_constraintTop_toBottomOf="@id/summary_card" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/security_note"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="24dp"
            style="@style/TextAppearance.StudioCreativo.Mono"
            android:textSize="11sp"
            app:drawableStartCompat="@android:drawable/ic_lock_lock"
            app:drawableTint="@color/text_muted"
            android:drawablePadding="4dp"
            app:layout_constraintTop_toBottomOf="@id/btn_pay"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>