<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/base_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Title -->
        <TextView
            android:id="@+id/txt_customize_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/customize_title"
            style="@style/TextAppearance.StudioCreativo.Headline"
            android:textSize="24sp"
            android:layout_marginBottom="16dp" />

        <!-- Preview Card -->
        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.StudioCreativo.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/preview_label"
                    style="@style/TextAppearance.StudioCreativo.Mono"
                    android:padding="12dp" />

                <ImageView
                    android:id="@+id/img_preview"
                    android:layout_width="match_parent"
                    android:layout_height="250dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/gorra_snapback"
                    android:contentDescription="@string/preview_label" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Step 1: Color -->
        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.StudioCreativo.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/step_color"
                    style="@style/TextAppearance.StudioCreativo.Title"
                    android:textSize="16sp" />

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chip_group_colors"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:singleSelection="true">

                    <com.google.android.material.chip.Chip
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Black"
                        style="@style/Widget.StudioCreativo.Chip.Cyan"
                        android:checked="true" />
                    <com.google.android.material.chip.Chip
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="White"
                        style="@style/Widget.StudioCreativo.Chip.Cyan" />
                    <com.google.android.material.chip.Chip
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Neon Blue"
                        style="@style/Widget.StudioCreativo.Chip.Cyan" />

                </com.google.android.material.chip.ChipGroup>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Step 2: Size -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/step_size_container"
            style="@style/Widget.StudioCreativo.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/txt_step_size_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/step_size"
                    style="@style/TextAppearance.StudioCreativo.Title"
                    android:textSize="16sp" />

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chip_group_sizes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:singleSelection="true">

                    <com.google.android.material.chip.Chip
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/size_s"
                        style="@style/Widget.StudioCreativo.Chip.Purple" />
                    <com.google.android.material.chip.Chip
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/size_m"
                        style="@style/Widget.StudioCreativo.Chip.Purple"
                        android:checked="true" />
                    <com.google.android.material.chip.Chip
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/size_l"
                        style="@style/Widget.StudioCreativo.Chip.Purple" />
                    <com.google.android.material.chip.Chip
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/size_xl"
                        style="@style/Widget.StudioCreativo.Chip.Purple" />

                </com.google.android.material.chip.ChipGroup>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Step 3: Design Base -->
        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.StudioCreativo.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/step_design"
                    style="@style/TextAppearance.StudioCreativo.Title"
                    android:textSize="16sp" />

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chip_group_design"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:singleSelection="true">

                    <com.google.android.material.chip.Chip
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Minimalist"
                        style="@style/Widget.StudioCreativo.Chip.Green"
                        android:checked="true" />
                    <com.google.android.material.chip.Chip
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tech"
                        style="@style/Widget.StudioCreativo.Chip.Green" />
                    <com.google.android.material.chip.Chip
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Retro"
                        style="@style/Widget.StudioCreativo.Chip.Green" />

                </com.google.android.material.chip.ChipGroup>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Step 4: Upload -->
        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.StudioCreativo.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/step_upload"
                    style="@style/TextAppearance.StudioCreativo.Title"
                    android:textSize="16sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_upload"
                    style="@style/Widget.StudioCreativo.Button.Secondary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/btn_upload_file"
                    app:icon="@drawable/edit_24px" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Step 5: Instructions -->
        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.StudioCreativo.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/step_instructions"
                    style="@style/TextAppearance.StudioCreativo.Title"
                    android:textSize="16sp" />

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.StudioCreativo.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:hint="@string/instructions_hint">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_instructions"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minLines="3"
                        android:gravity="top"
                        android:textColor="@color/text_primary" />

                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Step 6: Quantity -->
        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.StudioCreativo.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/step_quantity"
                    style="@style/TextAppearance.StudioCreativo.Title"
                    android:textSize="16sp" />

                <!-- Simple Number Picker Simulation -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_minus"
                    style="@style/Widget.Material3.Button.IconButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="-" />

                <TextView
                    android:id="@+id/txt_quantity"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1"
                    android:paddingHorizontal="16dp"
                    style="@style/TextAppearance.StudioCreativo.Title" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_plus"
                    style="@style/Widget.Material3.Button.IconButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Summary & Buy -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_add_to_cart_final"
            style="@style/Widget.StudioCreativo.Button.Green"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="@string/btn_add_to_cart"
            android:textSize="18sp"
            android:layout_marginBottom="12dp"
            app:icon="@drawable/add_24px" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_buy_now"
            style="@style/Widget.StudioCreativo.Button.Cyan"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="PAGAR AHORA"
            android:textSize="18sp"
            android:layout_marginBottom="16dp"
            app:icon="@drawable/shopping_cart_24px" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
