<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/base_background"
    android:fillViewport="true"
    tools:context=".fragments.HomeFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <!-- Hero Section -->
        <ImageView
            android:id="@+id/hero_logo"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:src="@drawable/logo1_fondo"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:contentDescription="@string/desc_logo" />

        <TextView
            android:id="@+id/hero_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/hero_title"
            android:gravity="center"
            android:layout_marginTop="16dp"
            style="@style/TextAppearance.StudioCreativo.Headline"
            app:layout_constraintTop_toBottomOf="@id/hero_logo" />

        <TextView
            android:id="@+id/hero_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/hero_subtitle"
            android:gravity="center"
            android:layout_marginTop="8dp"
            style="@style/TextAppearance.StudioCreativo.Body"
            app:layout_constraintTop_toBottomOf="@id/hero_title" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_explore_catalog"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/btn_view_catalog"
            android:layout_marginTop="24dp"
            style="@style/Widget.StudioCreativo.Button.Cyan"
            app:layout_constraintTop_toBottomOf="@id/hero_subtitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Stats Section -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/stats_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            style="@style/Widget.StudioCreativo.Card"
            app:layout_constraintTop_toBottomOf="@id/btn_explore_catalog">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:baselineAligned="false">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/star_24px"
                        app:tint="@color/primary_cyan"
                        android:contentDescription="@null" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="500+"
                        android:layout_marginTop="4dp"
                        style="@style/TextAppearance.StudioCreativo.Title" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/stats_projects"
                        style="@style/TextAppearance.StudioCreativo.Mono" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/chartlogo"
                        app:tint="@color/success_neon_green"
                        android:contentDescription="@null" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="99%"
                        android:layout_marginTop="4dp"
                        style="@style/TextAppearance.StudioCreativo.Title" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/stats_success"
                        style="@style/TextAppearance.StudioCreativo.Mono" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/add_24px"
                        app:tint="@color/secondary_purple"
                        android:contentDescription="@null" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="24h"
                        android:layout_marginTop="4dp"
                        style="@style/TextAppearance.StudioCreativo.Title" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/stats_delivery"
                        style="@style/TextAppearance.StudioCreativo.Mono" />
                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Featured Section -->
        <TextView
            android:id="@+id/featured_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/section_specialties"
            android:layout_marginTop="40dp"
            style="@style/TextAppearance.StudioCreativo.Title"
            app:layout_constraintTop_toBottomOf="@id/stats_card"
            app:layout_constraintStart_toStartOf="parent" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_spec_sublimation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            style="@style/Widget.StudioCreativo.Card"
            app:layout_constraintTop_toBottomOf="@id/featured_title">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">

                <ImageView
                    android:id="@+id/spec_icon_1"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/tazapixel_glow"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    android:contentDescription="@string/desc_service_image" />

                <TextView
                    android:id="@+id/spec_name_1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/service_sublimation_title"
                    android:layout_marginStart="16dp"
                    style="@style/TextAppearance.StudioCreativo.Title"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toEndOf="@id/spec_icon_1"
                    app:layout_constraintEnd_toEndOf="parent" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/service_sublimation_desc"
                    style="@style/TextAppearance.StudioCreativo.Body"
                    app:layout_constraintTop_toBottomOf="@id/spec_name_1"
                    app:layout_constraintStart_toStartOf="@id/spec_name_1"
                    app:layout_constraintEnd_toEndOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_spec_hd"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            style="@style/Widget.StudioCreativo.Card"
            app:layout_constraintTop_toBottomOf="@id/card_spec_sublimation">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">

                <ImageView
                    android:id="@+id/spec_icon_2"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/gorra_snapback"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    android:contentDescription="@string/desc_service_image" />

                <TextView
                    android:id="@+id/spec_name_2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/service_hd_printing_title"
                    android:layout_marginStart="16dp"
                    style="@style/TextAppearance.StudioCreativo.Title"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toEndOf="@id/spec_icon_2"
                    app:layout_constraintEnd_toEndOf="parent" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/service_hd_printing_desc"
                    style="@style/TextAppearance.StudioCreativo.Body"
                    app:layout_constraintTop_toBottomOf="@id/spec_name_2"
                    app:layout_constraintStart_toStartOf="@id/spec_name_2"
                    app:layout_constraintEnd_toEndOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>