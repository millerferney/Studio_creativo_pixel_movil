<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="8dp"
    android:gravity="center_vertical">

    <ImageView
        android:id="@+id/img_cart_item"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:scaleType="centerCrop"
        android:src="@drawable/vasostanley_custom" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="12dp">

        <TextView
            android:id="@+id/txt_cart_item_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Producto"
            style="@style/TextAppearance.StudioCreativo.Title"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/txt_cart_item_price"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="$0.00"
            style="@style/TextAppearance.StudioCreativo.Mono"
            android:textSize="12sp" />

    </LinearLayout>

    <ImageButton
        android:id="@+id/btn_remove_item"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/delete_24px"
        app:tint="@color/error_red"
        android:contentDescription="@string/app_name" />

</LinearLayout>
