<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/base_background"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <TextView
            android:id="@+id/services_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/services_title"
            style="@style/TextAppearance.StudioCreativo.Headline"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/services_desc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/services_desc"
            android:layout_marginTop="8dp"
            style="@style/TextAppearance.StudioCreativo.Body"
            app:layout_constraintTop_toBottomOf="@id/services_title" />

        <!-- Services Grid Simulating the 4 pillars -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_sublimation"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="8dp"
            style="@style/Widget.StudioCreativo.Card"
            app:layout_constraintTop_toBottomOf="@id/services_desc"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/card_hd_printing">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/edit_24px"
                    app:tint="@color/primary_cyan"
                    android:contentDescription="@null" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/service_sublimation_title"
                    android:layout_marginTop="8dp"
                    style="@style/TextAppearance.StudioCreativo.Title"
                    android:textSize="16sp" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/service_sublimation_desc"
                    style="@style/TextAppearance.StudioCreativo.Body"
                    android:textSize="12sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_hd_printing"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            style="@style/Widget.StudioCreativo.Card"
            app:layout_constraintTop_toTopOf="@id/card_sublimation"
            app:layout_constraintStart_toEndOf="@id/card_sublimation"
            app:layout_constraintEnd_toEndOf="parent">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/chartlogo"
                    app:tint="@color/primary_cyan"
                    android:contentDescription="@null" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/service_hd_printing_title"
                    android:layout_marginTop="8dp"
                    style="@style/TextAppearance.StudioCreativo.Title"
                    android:textSize="16sp" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/service_hd_printing_desc"
                    style="@style/TextAppearance.StudioCreativo.Body"
                    android:textSize="12sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_industrial"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="8dp"
            style="@style/Widget.StudioCreativo.Card"
            app:layout_constraintTop_toBottomOf="@id/card_sublimation"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/card_design">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/star_24px"
                    app:tint="@color/primary_cyan"
                    android:contentDescription="@null" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/service_industrial_title"
                    android:layout_marginTop="8dp"
                    style="@style/TextAppearance.StudioCreativo.Title"
                    android:textSize="16sp" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/service_industrial_desc"
                    style="@style/TextAppearance.StudioCreativo.Body"
                    android:textSize="12sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_design"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            style="@style/Widget.StudioCreativo.Card"
            app:layout_constraintTop_toTopOf="@id/card_industrial"
            app:layout_constraintStart_toEndOf="@id/card_industrial"
            app:layout_constraintEnd_toEndOf="parent">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/logo1_fondo"
                    app:tint="@color/primary_cyan"
                    android:contentDescription="@null" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/service_design_title"
                    android:layout_marginTop="8dp"
                    style="@style/TextAppearance.StudioCreativo.Title"
                    android:textSize="16sp" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/service_design_desc"
                    style="@style/TextAppearance.StudioCreativo.Body"
                    android:textSize="12sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/top_products_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/top_products_title"
            android:layout_marginTop="32dp"
            style="@style/TextAppearance.StudioCreativo.Title"
            app:layout_constraintTop_toBottomOf="@id/card_industrial"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Mock of Top Products -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:scrollbars="none"
            app:layout_constraintTop_toBottomOf="@id/top_products_label">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Product 1 -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="160dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="12dp"
                    style="@style/Widget.StudioCreativo.Card">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="120dp"
                            android:contentDescription="@string/desc_product_image"
                            android:scaleType="centerCrop"
                            android:src="@drawable/tazapixel_glow" />
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/product_mug_name"
                            android:layout_marginTop="8dp"
                            style="@style/TextAppearance.StudioCreativo.Title"
                            android:textSize="14sp" />
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/product_mug_price"
                            style="@style/TextAppearance.StudioCreativo.Mono" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Product 2 -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="160dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="12dp"
                    style="@style/Widget.StudioCreativo.Card">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">
                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="120dp"
                            android:scaleType="centerCrop"
                            android:src="@drawable/gorra_snapback"
                            android:contentDescription="@string/desc_product_image" />
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/product_cap_name"
                            android:layout_marginTop="8dp"
                            style="@style/TextAppearance.StudioCreativo.Title"
                            android:textSize="14sp" />
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/product_cap_price"
                            style="@style/TextAppearance.StudioCreativo.Mono" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </HorizontalScrollView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>